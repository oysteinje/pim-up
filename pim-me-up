#!/usr/bin/env bash
set -euo pipefail

# =============================================================================
# pim-me-up — Fast Azure PIM activation from the terminal
# =============================================================================

# -----------------------------------------------------------------------------
# Constants & Configuration
# -----------------------------------------------------------------------------

PIM_API="https://api.azrbac.mspim.azure.com"
ARM_API="https://management.azure.com"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m' # No Color

# Duration options (hours)
DURATION_OPTIONS=("1h" "2h" "4h" "8h")

# fzf configuration — dynamic height (~) requires fzf 0.30+
if fzf --height=~1 </dev/null >/dev/null 2>&1; then
    FZF_COMMON=(--height=~50% --border --margin=1,2)
else
    FZF_COMMON=(--height=50% --border --margin=1,2)
fi
FZF_SINGLE=("${FZF_COMMON[@]}" --no-multi)
FZF_MULTI=("${FZF_COMMON[@]}" --multi --bind=space:toggle,ctrl-a:toggle-all)

# fzf headers — pass bare: fzf ... $FZF_HEADER_* (flag is part of the value)
FZF_HEADER_CATEGORY="--header=Select PIM category (Esc to exit)"
FZF_HEADER_ROLES="--header=Space/Tab=select  Enter=confirm  Ctrl-A=all  Esc=back"
FZF_HEADER_DURATION="--header=Select activation duration (Esc=back)"
FZF_HEADER_SUBS="--header=Select subscriptions (Space=toggle  Ctrl-A=all  Esc=back)"

# Session state
USER_ID=""

# Session caching — populated by Epic 2 stories
CACHE_ENTRA=""     # cached eligible Entra ID Roles JSON
CACHE_GROUPS=""    # cached eligible PIM Groups JSON
CACHE_ARM=""       # cached eligible Azure Resource roles JSON (per subscription)
CACHE_SUBS=""      # cached subscription list JSON

# -----------------------------------------------------------------------------
# Utility Functions
# -----------------------------------------------------------------------------

die() {
    local msg="$1"
    local code="${2:-1}"
    printf "${RED}Error: %s${NC}\n" "$msg" >&2
    exit "$code"
}

check_deps() {
    local missing=()
    local deps=(fzf jq az curl)

    for dep in "${deps[@]}"; do
        if ! command -v "$dep" &>/dev/null; then
            missing+=("$dep")
        fi
    done

    if [[ ${#missing[@]} -gt 0 ]]; then
        die "Missing required dependencies: $(IFS=', '; echo "${missing[*]}")"
    fi
}

get_user_id() {
    local user_json
    if ! user_json=$(az ad signed-in-user show 2>/dev/null); then
        die "Run \`az login\` first"
    fi

    USER_ID=$(echo "$user_json" | jq -r '.id')
    if [[ -z "$USER_ID" || "$USER_ID" == "null" ]]; then
        die "Failed to retrieve user ID from Azure AD"
    fi

    local org_json
    org_json=$(az rest --method GET --url "https://graph.microsoft.com/v1.0/organization" 2>/dev/null) || true
    local tenant_name
    tenant_name=$(echo "$org_json" | jq -r '.value[0].displayName // empty' 2>/dev/null) || tenant_name=""

    if [[ -z "$tenant_name" ]]; then
        local account_json
        account_json=$(az account show 2>/dev/null) || true
        tenant_name=$(echo "$account_json" | jq -r '.tenantDisplayName // .name // "unknown"' 2>/dev/null) || tenant_name="unknown"
    fi

    printf "${GREEN}Logged in${NC} — Tenant: %s\n" "$tenant_name"
}

gen_uuid() {
    if [[ -r /proc/sys/kernel/random/uuid ]]; then
        cat /proc/sys/kernel/random/uuid
    else
        uuidgen || die "Cannot generate UUID — install uuidgen or run on Linux"
    fi
}

iso_now() {
    date -u +%Y-%m-%dT%H:%M:%SZ
}

# -----------------------------------------------------------------------------
# API Functions
# -----------------------------------------------------------------------------

fetch_active_pim() {
    local category="$1"  # "aadroles" or "aadGroups"
    local result
    result=$(az rest --resource "$PIM_API" --method GET \
        --url "$PIM_API/api/v2/privilegedAccess/$category/roleAssignments?\$filter=subjectId eq '$USER_ID' and assignmentState eq 'Active'" \
        2>/dev/null) || { echo '{"value":[]}'; return 0; }
    echo "$result"
}

fetch_active_arm() {
    local result
    result=$(az rest --method GET \
        --url "$ARM_API/providers/Microsoft.Authorization/roleAssignmentScheduleInstances?\$filter=asTarget()&api-version=2020-10-01" \
        2>/dev/null) || { echo '{"value":[]}'; return 0; }
    echo "$result"
}

pim_list_eligible() {
    local category="$1"  # "aadroles" or "aadGroups"
    local result
    if ! result=$(az rest --resource "$PIM_API" --method GET \
        --url "$PIM_API/api/v2/privilegedAccess/$category/roleAssignments?\$filter=subjectId eq '$USER_ID' and assignmentState eq 'Eligible'&\$expand=roleDefinition(\$expand=resource)" \
        2>/dev/null); then
        printf "${RED}Error fetching eligible %s — check az login and PIM permissions${NC}\n" "$category" >&2
        return 1
    fi
    echo "$result"
}

arm_list_eligible() {
    local sub_id="$1"
    local result
    if ! result=$(az rest --method GET \
        --url "$ARM_API/subscriptions/$sub_id/providers/Microsoft.Authorization/roleEligibilityScheduleInstances?\$filter=asTarget() and status eq 'Provisioned'&api-version=2020-10-01" \
        2>/dev/null); then
        printf "${RED}Error fetching eligible ARM roles for subscription %s${NC}\n" "$sub_id" >&2
        return 1
    fi
    echo "$result"
}

pim_activate() {
    local category="$1"       # "aadroles" or "aadGroups"
    local role_def_id="$2"
    local resource_id="$3"
    local duration_hours="$4"  # "1h", "2h", etc.
    local justification="$5"

    local n="${duration_hours%h}"
    local now
    now=$(iso_now)

    local payload
    payload=$(jq -n \
        --arg rdid "$role_def_id" \
        --arg resid "$resource_id" \
        --arg uid "$USER_ID" \
        --arg reason "$justification" \
        --arg dur "PT${n}H" \
        --arg now "$now" \
        '{roleDefinitionId:$rdid,resourceId:$resid,subjectId:$uid,
          assignmentState:"Active",type:"UserAdd",reason:$reason,
          schedule:{type:"Once",startDateTime:$now,duration:$dur}}')

    az rest --resource "$PIM_API" --method POST \
        --url "$PIM_API/api/v2/privilegedAccess/$category/roleAssignmentRequests" \
        --body "$payload" >/dev/null
}

arm_activate() {
    local scope="$1"
    local role_def_id="$2"
    local duration_hours="$3"
    local justification="$4"

    local n="${duration_hours%h}"
    local uuid now payload
    uuid=$(gen_uuid)
    now=$(iso_now)

    payload=$(jq -n \
        --arg pid "$USER_ID" \
        --arg rdid "$role_def_id" \
        --arg just "$justification" \
        --arg now "$now" \
        --arg dur "PT${n}H" \
        '{properties:{principalId:$pid,roleDefinitionId:$rdid,requestType:"SelfActivate",
          justification:$just,scheduleInfo:{startDateTime:$now,
          expiration:{type:"AfterDuration",duration:$dur}}}}')

    az rest --method PUT \
        --url "${ARM_API}${scope}/providers/Microsoft.Authorization/roleAssignmentScheduleRequests/${uuid}?api-version=2020-10-01" \
        --body "$payload" >/dev/null
}

# -----------------------------------------------------------------------------
# Display Formatting
# -----------------------------------------------------------------------------

format_pim_roles() {
    local json="$1"
    jq -r '.value[].roleDefinition.displayName // empty' <<< "$json" 2>/dev/null
}

format_pim_groups() {
    local json="$1"
    jq -r '.value[].roleDefinition.resource.displayName // empty' <<< "$json" 2>/dev/null
}

format_arm_roles() {
    local json="$1"
    jq -r '.value[] | (.properties.expandedProperties.roleDefinition.displayName // "unknown") + " (" + (.properties.expandedProperties.scope.displayName // "unknown") + ")"' <<< "$json" 2>/dev/null
}

format_entra_eligible() {
    local json="$1"
    jq -r '.value[] |
        (.roleDefinition.displayName // "unknown") + " | " +
        (.roleDefinition.resource.displayName // "unknown") +
        "\t" +
        "roleDefinitionId=" + (.roleDefinitionId // "unknown") +
        "&resourceId=" + (.resourceId // "unknown")' <<< "$json" 2>/dev/null
}

format_groups_eligible() {
    local json="$1"
    jq -r '.value[] |
        (.roleDefinition.resource.displayName // "unknown") + " | " +
        (.roleDefinition.displayName // "member") +
        "\t" +
        "roleDefinitionId=" + (.roleDefinitionId // "unknown") +
        "&resourceId=" + (.resourceId // "unknown")' <<< "$json" 2>/dev/null
}

format_arm_eligible() {
    local json="$1"
    jq -r '.value[] |
        (.properties.expandedProperties.roleDefinition.displayName // "unknown") + " | " +
        (.properties.expandedProperties.scope.displayName // "unknown") +
        "\t" +
        "roleDefinitionId=" + (.properties.roleDefinitionId // "") +
        "&scope=" + (.properties.scope // "")' <<< "$json" 2>/dev/null
}

# -----------------------------------------------------------------------------
# UI Flow Functions
# -----------------------------------------------------------------------------

show_active_assignments() {
    local tmpdir
    tmpdir=$(mktemp -d)
    trap "rm -rf '$tmpdir'" RETURN

    # Launch all three fetches in background
    fetch_active_pim "aadroles" > "$tmpdir/entra" 2>/dev/null &
    local pid_entra=$!
    fetch_active_pim "aadGroups" > "$tmpdir/groups" 2>/dev/null &
    local pid_groups=$!
    fetch_active_arm > "$tmpdir/arm" 2>/dev/null &
    local pid_arm=$!

    # Wait up to 1 second using millisecond wall-clock polling
    local deadline_ms=$(( $(date +%s%3N) + 1000 ))
    while (( $(date +%s%3N) < deadline_ms )); do
        # Check if all processes have finished
        if ! kill -0 "$pid_entra" 2>/dev/null && \
           ! kill -0 "$pid_groups" 2>/dev/null && \
           ! kill -0 "$pid_arm" 2>/dev/null; then
            break
        fi
        sleep 0.1
    done

    # If any still running, kill them and silently skip
    local timed_out=false
    for pid in $pid_entra $pid_groups $pid_arm; do
        if kill -0 "$pid" 2>/dev/null; then
            timed_out=true
            kill "$pid" 2>/dev/null || true
        fi
    done
    wait "$pid_entra" "$pid_groups" "$pid_arm" 2>/dev/null || true

    if $timed_out; then
        return 0  # silently skip on timeout
    fi

    # Parse results
    local entra_json groups_json arm_json
    entra_json=$(<"$tmpdir/entra")
    groups_json=$(<"$tmpdir/groups")
    arm_json=$(<"$tmpdir/arm")

    local entra_names groups_names arm_names
    entra_names=$(format_pim_roles "$entra_json")
    groups_names=$(format_pim_groups "$groups_json")
    arm_names=$(format_arm_roles "$arm_json")

    local entra_count groups_count arm_count total
    entra_count=$(echo "$entra_names" | grep -c . 2>/dev/null) || entra_count=0
    groups_count=$(echo "$groups_names" | grep -c . 2>/dev/null) || groups_count=0
    arm_count=$(echo "$arm_names" | grep -c . 2>/dev/null) || arm_count=0
    total=$((entra_count + groups_count + arm_count))

    if (( total == 0 )); then
        echo "No active PIM assignments"
        return 0
    fi

    printf "${YELLOW}Active PIM Assignments:${NC}\n"
    if (( entra_count > 0 )); then
        printf "  Entra ID Roles (%d): %s\n" "$entra_count" "$(echo "$entra_names" | paste -sd', ')"
    fi
    if (( groups_count > 0 )); then
        printf "  PIM Groups (%d): %s\n" "$groups_count" "$(echo "$groups_names" | paste -sd', ')"
    fi
    if (( arm_count > 0 )); then
        printf "  Azure Resources (%d): %s\n" "$arm_count" "$(echo "$arm_names" | paste -sd', ')"
    fi
}

pick_category() {
    local selection
    selection=$(printf '%s\n' \
        "Entra ID Roles" \
        "PIM Groups" \
        "Azure Resources" \
        | fzf "${FZF_SINGLE[@]}" "$FZF_HEADER_CATEGORY") || return 1
    echo "$selection"
}

pick_roles() {
    local lines="$1"
    local prev_selections="${2:-}"

    local fzf_input="$lines"
    local bind_arg=""

    # Sort previously-selected items to top and pre-toggle them via fzf start binding
    if [[ -n "$prev_selections" && -n "$lines" ]]; then
        local matched_count=0
        local matched_lines="" other_lines=""

        while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            if grep -qxF "$line" <<< "$prev_selections" 2>/dev/null; then
                matched_count=$(( matched_count + 1 ))
                matched_lines+="${line}"$'\n'
            else
                other_lines+="${line}"$'\n'
            fi
        done < <(printf '%s' "$lines")

        if (( matched_count > 0 )); then
            fzf_input="${matched_lines}${other_lines}"
            # Generate start binding: toggle first matched_count items, then move cursor back up
            local bind_seq="toggle"
            for (( i=1; i<matched_count; i++ )); do
                bind_seq+="+down+toggle"
            done
            for (( i=1; i<matched_count; i++ )); do
                bind_seq+="+up"
            done
            bind_arg="--bind=start:${bind_seq}"
        fi
    fi

    local selected
    if [[ -n "$bind_arg" ]]; then
        selected=$(printf '%s' "$fzf_input" | fzf "${FZF_MULTI[@]}" "$FZF_HEADER_ROLES" \
            --with-nth=1 --delimiter=$'\t' "$bind_arg") || return 1
    else
        selected=$(printf '%s' "$fzf_input" | fzf "${FZF_MULTI[@]}" "$FZF_HEADER_ROLES" \
            --with-nth=1 --delimiter=$'\t') || return 1
    fi

    echo "$selected"
}

pick_subscriptions() {
    local subs_json
    if ! subs_json=$(az account list --output json 2>/dev/null); then
        printf "${RED}Error fetching subscriptions — check az login${NC}\n" >&2
        return 1
    fi

    local count
    count=$(jq 'length' <<< "$subs_json" 2>/dev/null) || count=0
    if (( count == 0 )); then
        printf "${YELLOW}No subscriptions found${NC}\n"
        return 1
    fi

    local lines
    lines=$(jq -r '.[] | (.name // "unknown") + " (" + (.id // "") + ")" + "\t" + (.id // "")' \
        <<< "$subs_json" 2>/dev/null)

    local selected
    selected=$(printf '%s\n' "$lines" | fzf "${FZF_MULTI[@]}" "$FZF_HEADER_SUBS" \
        --with-nth=1 --delimiter=$'\t') || return 1

    if [[ -z "$selected" ]]; then
        return 1
    fi

    printf '%s\n' "$selected" | cut -d$'\t' -f2
}

pick_duration() {
    local selected
    selected=$(printf '%s\n' "1h" "2h" "4h" "8h" \
        | fzf "${FZF_SINGLE[@]}" "$FZF_HEADER_DURATION") || return 1
    echo "$selected"
}

get_justification() {
    local default="PIM activation via script"
    local output
    output=$(echo "" | fzf "${FZF_SINGLE[@]}" \
        --header="Enter justification (Esc=back to duration picker)" \
        --query="$default" \
        --print-query \
        --disabled \
        --prompt="Justification: ") || return 1
    local reason
    reason=$(printf '%s' "$output" | head -1)
    echo "${reason:-$default}"
}

flow_entra_roles() {
    local prev_selections="${1:-}"

    if [[ -z "$CACHE_ENTRA" ]]; then
        local json
        json=$(pim_list_eligible "aadroles") || return 1

        local count
        count=$(jq -r '.value | length' <<< "$json" 2>/dev/null) || count=0
        if (( count == 0 )); then
            printf "${YELLOW}No eligible assignments found for Entra ID Roles${NC}\n"
            return 1
        fi
        CACHE_ENTRA="$json"
    fi

    local lines
    lines=$(format_entra_eligible "$CACHE_ENTRA")
    if [[ -z "$lines" ]]; then
        printf "${YELLOW}No eligible assignments found for Entra ID Roles${NC}\n"
        return 1
    fi
    pick_roles "$lines" "$prev_selections" || return 1
}

flow_pim_groups() {
    local prev_selections="${1:-}"

    if [[ -z "$CACHE_GROUPS" ]]; then
        local json
        json=$(pim_list_eligible "aadGroups") || return 1

        local count
        count=$(jq -r '.value | length' <<< "$json" 2>/dev/null) || count=0
        if (( count == 0 )); then
            printf "${YELLOW}No eligible assignments found for PIM Groups${NC}\n"
            return 1
        fi
        CACHE_GROUPS="$json"
    fi

    local lines
    lines=$(format_groups_eligible "$CACHE_GROUPS")
    if [[ -z "$lines" ]]; then
        printf "${YELLOW}No eligible assignments found for PIM Groups${NC}\n"
        return 1
    fi
    pick_roles "$lines" "$prev_selections" || return 1
}

flow_azure_resources() {
    local prev_selections="${1:-}"

    # Use cached ARM lines if available (skip sub picker and API fetch on back-navigation)
    if [[ -n "$CACHE_ARM" ]]; then
        pick_roles "$CACHE_ARM" "$prev_selections" || return 1
        return 0
    fi

    # Cache subscription IDs to avoid re-prompting on back-navigation
    local sub_ids
    if [[ -n "$CACHE_SUBS" ]]; then
        sub_ids="$CACHE_SUBS"
    else
        sub_ids=$(pick_subscriptions) || return 1
        CACHE_SUBS="$sub_ids"
    fi

    local all_lines=""
    while IFS= read -r sub_id; do
        [[ -z "$sub_id" ]] && continue
        local json
        if ! json=$(arm_list_eligible "$sub_id"); then
            continue  # warning already printed to stderr by arm_list_eligible
        fi

        local count
        count=$(jq -r '.value | length' <<< "$json" 2>/dev/null) || count=0
        (( count == 0 )) && continue

        local lines
        lines=$(format_arm_eligible "$json")
        [[ -z "$lines" ]] && continue

        if [[ -z "$all_lines" ]]; then
            all_lines="$lines"
        else
            all_lines+=$'\n'"$lines"
        fi
    done <<< "$sub_ids"

    if [[ -z "$all_lines" ]]; then
        printf "${YELLOW}No eligible assignments found for Azure Resources${NC}\n"
        return 1
    fi

    CACHE_ARM="$all_lines"
    pick_roles "$all_lines" "$prev_selections" || return 1
}

# -----------------------------------------------------------------------------
# Activation Orchestration
# -----------------------------------------------------------------------------

activate_batch() {
    local category="$1"
    local selections="$2"
    local duration="$3"
    local justification="$4"

    local had_failure=false
    printf "\nActivating roles...\n"

    while IFS= read -r line; do
        [[ -z "$line" ]] && continue

        local display meta
        display=$(cut -d$'\t' -f1 <<< "$line")
        meta=$(cut -d$'\t' -f2 <<< "$line")

        # Parse roleDefinitionId (always first key before &)
        local role_def_id="${meta%%&*}"
        role_def_id="${role_def_id#roleDefinitionId=}"

        printf "  %s... " "$display"

        local err="" activation_ok=true
        case "$category" in
            "Entra ID Roles")
                local resource_id="${meta#*resourceId=}"
                err=$(pim_activate "aadroles" "$role_def_id" "$resource_id" "$duration" "$justification" 2>&1) || activation_ok=false
                ;;
            "PIM Groups")
                local resource_id="${meta#*resourceId=}"
                err=$(pim_activate "aadGroups" "$role_def_id" "$resource_id" "$duration" "$justification" 2>&1) || activation_ok=false
                ;;
            "Azure Resources")
                local scope="${meta#*scope=}"
                err=$(arm_activate "$scope" "$role_def_id" "$duration" "$justification" 2>&1) || activation_ok=false
                ;;
        esac

        if $activation_ok; then
            printf "${GREEN}✓${NC}\n"
        else
            printf "${RED}✗${NC}\n"
            printf "    ${RED}%s${NC}\n" "$err"
            had_failure=true
        fi
    done <<< "$selections"

    if $had_failure; then
        printf "\n${YELLOW}Some activations failed. See errors above.${NC}\n"
    else
        printf "\n${GREEN}All activations successful.${NC}\n"
    fi
}

# -----------------------------------------------------------------------------
# Main
# -----------------------------------------------------------------------------

main() {
    trap 'exit 0' INT TERM   # Ctrl-C anywhere → clean exit

    check_deps
    get_user_id
    show_active_assignments

    while true; do
        local category
        category=$(pick_category) || exit 0

        local selected_roles="" duration="" justification=""
        local step="roles"

        while true; do
            case "$step" in
                "roles")
                    local new_roles
                    case "$category" in
                        "Entra ID Roles")
                            new_roles=$(flow_entra_roles "$selected_roles") || break ;;
                        "PIM Groups")
                            new_roles=$(flow_pim_groups "$selected_roles") || break ;;
                        "Azure Resources")
                            new_roles=$(flow_azure_resources "$selected_roles") || break ;;
                    esac
                    selected_roles="$new_roles"
                    step="duration"
                    ;;
                "duration")
                    local new_duration
                    new_duration=$(pick_duration) || { step="roles"; continue; }
                    duration="$new_duration"
                    step="justification"
                    ;;
                "justification")
                    local new_justification
                    new_justification=$(get_justification) || { step="duration"; continue; }
                    justification="$new_justification"
                    step="activate"
                    ;;
                "activate")
                    activate_batch "$category" "$selected_roles" "$duration" "$justification"
                    break
                    ;;
            esac
        done
    done
}

main "$@"
