#!/usr/bin/env bash
set -euo pipefail

# =============================================================================
# pim-me-up — Fast Azure PIM activation from the terminal
# =============================================================================

# -----------------------------------------------------------------------------
# Constants & Configuration
# -----------------------------------------------------------------------------

PIM_API="https://api.azrbac.mspim.azure.com"
ARM_API="https://management.azure.com"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m' # No Color

# Duration options (hours)
DURATION_OPTIONS=("1h" "2h" "4h" "8h")

# fzf configuration — dynamic height (~) requires fzf 0.30+
if fzf --height=~1 </dev/null >/dev/null 2>&1; then
    FZF_COMMON="--height=~50% --border --margin=1,2"
else
    FZF_COMMON="--height=50% --border --margin=1,2"
fi
FZF_SINGLE="$FZF_COMMON --no-multi"
FZF_MULTI="$FZF_COMMON --multi --bind=space:toggle,ctrl-a:toggle-all"

# fzf headers — pass as: --header="$FZF_HEADER_*" (not bare, to avoid word splitting)
FZF_HEADER_CATEGORY="Select PIM category (Esc to exit)"
FZF_HEADER_ROLES="Space/Tab=select  Enter=confirm  Ctrl-A=all  Esc=back"
FZF_HEADER_DURATION="Select activation duration (Esc=back)"

# Session state
USER_ID=""

# Session caching — populated by Epic 2 stories
CACHE_ENTRA=""     # cached eligible Entra ID Roles JSON
CACHE_GROUPS=""    # cached eligible PIM Groups JSON
CACHE_ARM=""       # cached eligible Azure Resource roles JSON (per subscription)
CACHE_SUBS=""      # cached subscription list JSON

# -----------------------------------------------------------------------------
# Utility Functions
# -----------------------------------------------------------------------------

die() {
    local msg="$1"
    local code="${2:-1}"
    printf "${RED}Error: %s${NC}\n" "$msg" >&2
    exit "$code"
}

check_deps() {
    local missing=()
    local deps=(fzf jq az curl)

    for dep in "${deps[@]}"; do
        if ! command -v "$dep" &>/dev/null; then
            missing+=("$dep")
        fi
    done

    if [[ ${#missing[@]} -gt 0 ]]; then
        die "Missing required dependencies: $(IFS=', '; echo "${missing[*]}")"
    fi
}

get_user_id() {
    local user_json
    if ! user_json=$(az ad signed-in-user show 2>/dev/null); then
        die "Run \`az login\` first"
    fi

    USER_ID=$(echo "$user_json" | jq -r '.id')
    if [[ -z "$USER_ID" || "$USER_ID" == "null" ]]; then
        die "Failed to retrieve user ID from Azure AD"
    fi

    local org_json
    org_json=$(az rest --method GET --url "https://graph.microsoft.com/v1.0/organization" 2>/dev/null) || true
    local tenant_name
    tenant_name=$(echo "$org_json" | jq -r '.value[0].displayName // empty' 2>/dev/null) || tenant_name=""

    if [[ -z "$tenant_name" ]]; then
        local account_json
        account_json=$(az account show 2>/dev/null) || true
        tenant_name=$(echo "$account_json" | jq -r '.tenantDisplayName // .name // "unknown"' 2>/dev/null) || tenant_name="unknown"
    fi

    printf "${GREEN}Logged in${NC} — Tenant: %s\n" "$tenant_name"
}

gen_uuid() {
    if [[ -r /proc/sys/kernel/random/uuid ]]; then
        cat /proc/sys/kernel/random/uuid
    else
        uuidgen || die "Cannot generate UUID — install uuidgen or run on Linux"
    fi
}

iso_now() {
    date -u +%Y-%m-%dT%H:%M:%SZ
}

# -----------------------------------------------------------------------------
# API Functions
# -----------------------------------------------------------------------------

fetch_active_pim() {
    local category="$1"  # "aadroles" or "aadGroups"
    local result
    result=$(az rest --resource "$PIM_API" --method GET \
        --url "$PIM_API/api/v2/privilegedAccess/$category/roleAssignments?\$filter=subjectId eq '$USER_ID' and assignmentState eq 'Active'" \
        2>/dev/null) || { echo '{"value":[]}'; return 0; }
    echo "$result"
}

fetch_active_arm() {
    local result
    result=$(az rest --method GET \
        --url "$ARM_API/providers/Microsoft.Authorization/roleAssignmentScheduleInstances?\$filter=asTarget()&api-version=2020-10-01" \
        2>/dev/null) || { echo '{"value":[]}'; return 0; }
    echo "$result"
}

# -----------------------------------------------------------------------------
# Display Formatting
# -----------------------------------------------------------------------------

format_pim_roles() {
    local json="$1"
    jq -r '.value[].roleDefinition.displayName // empty' <<< "$json" 2>/dev/null
}

format_pim_groups() {
    local json="$1"
    jq -r '.value[].roleDefinition.resource.displayName // empty' <<< "$json" 2>/dev/null
}

format_arm_roles() {
    local json="$1"
    jq -r '.value[] | (.properties.expandedProperties.roleDefinition.displayName // "unknown") + " (" + (.properties.expandedProperties.scope.displayName // "unknown") + ")"' <<< "$json" 2>/dev/null
}

# -----------------------------------------------------------------------------
# UI Flow Functions
# -----------------------------------------------------------------------------

show_active_assignments() {
    local tmpdir
    tmpdir=$(mktemp -d)
    trap "rm -rf '$tmpdir'" RETURN

    # Launch all three fetches in background
    fetch_active_pim "aadroles" > "$tmpdir/entra" 2>/dev/null &
    local pid_entra=$!
    fetch_active_pim "aadGroups" > "$tmpdir/groups" 2>/dev/null &
    local pid_groups=$!
    fetch_active_arm > "$tmpdir/arm" 2>/dev/null &
    local pid_arm=$!

    # Wait up to 1 second using millisecond wall-clock polling
    local deadline_ms=$(( $(date +%s%3N) + 1000 ))
    while (( $(date +%s%3N) < deadline_ms )); do
        # Check if all processes have finished
        if ! kill -0 "$pid_entra" 2>/dev/null && \
           ! kill -0 "$pid_groups" 2>/dev/null && \
           ! kill -0 "$pid_arm" 2>/dev/null; then
            break
        fi
        sleep 0.1
    done

    # If any still running, kill them and silently skip
    local timed_out=false
    for pid in $pid_entra $pid_groups $pid_arm; do
        if kill -0 "$pid" 2>/dev/null; then
            timed_out=true
            kill "$pid" 2>/dev/null || true
        fi
    done
    wait "$pid_entra" "$pid_groups" "$pid_arm" 2>/dev/null || true

    if $timed_out; then
        return 0  # silently skip on timeout
    fi

    # Parse results
    local entra_json groups_json arm_json
    entra_json=$(<"$tmpdir/entra")
    groups_json=$(<"$tmpdir/groups")
    arm_json=$(<"$tmpdir/arm")

    local entra_names groups_names arm_names
    entra_names=$(format_pim_roles "$entra_json")
    groups_names=$(format_pim_groups "$groups_json")
    arm_names=$(format_arm_roles "$arm_json")

    local entra_count groups_count arm_count total
    entra_count=$(echo "$entra_names" | grep -c . 2>/dev/null) || entra_count=0
    groups_count=$(echo "$groups_names" | grep -c . 2>/dev/null) || groups_count=0
    arm_count=$(echo "$arm_names" | grep -c . 2>/dev/null) || arm_count=0
    total=$((entra_count + groups_count + arm_count))

    if (( total == 0 )); then
        echo "No active PIM assignments"
        return 0
    fi

    printf "${YELLOW}Active PIM Assignments:${NC}\n"
    if (( entra_count > 0 )); then
        printf "  Entra ID Roles (%d): %s\n" "$entra_count" "$(echo "$entra_names" | paste -sd', ')"
    fi
    if (( groups_count > 0 )); then
        printf "  PIM Groups (%d): %s\n" "$groups_count" "$(echo "$groups_names" | paste -sd', ')"
    fi
    if (( arm_count > 0 )); then
        printf "  Azure Resources (%d): %s\n" "$arm_count" "$(echo "$arm_names" | paste -sd', ')"
    fi
}

pick_category() {
    local selection
    selection=$(printf '%s\n' \
        "Entra ID Roles" \
        "PIM Groups" \
        "Azure Resources" \
        | fzf $FZF_SINGLE --header="$FZF_HEADER_CATEGORY") || return 1
    echo "$selection"
}

# -----------------------------------------------------------------------------
# Activation Orchestration
# -----------------------------------------------------------------------------

# (Added by later stories)

# -----------------------------------------------------------------------------
# Main
# -----------------------------------------------------------------------------

main() {
    trap 'exit 0' INT TERM   # Ctrl-C anywhere → clean exit

    check_deps
    get_user_id
    show_active_assignments

    while true; do
        local category
        category=$(pick_category) || exit 0

        # Placeholder — Epic 2 stories implement each branch
        # Story 2.1 replaces "Entra ID Roles" and "PIM Groups" branches
        # Story 2.2 replaces "Azure Resources" branch
        case "$category" in
            "Entra ID Roles"|"PIM Groups"|"Azure Resources")
                printf "${YELLOW}%s selected — role flow coming in Epic 2${NC}\n" "$category"
                ;;
        esac
        # Loop back to category picker (simulates Esc-from-role-picker for now)
    done
}

main "$@"
